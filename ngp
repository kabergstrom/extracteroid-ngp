#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
NGP_DIR="$SCRIPT_DIR/../newgameplus"

case "$(uname -s)" in
    Darwin) RAFX_FEATURE="rafx-vulkan" ;;
    Linux)  RAFX_FEATURE="rafx-vulkan" ;;
    *)      echo "Unsupported platform: $(uname -s)" >&2; exit 1 ;;
esac

# Build the extracteroid module
cargo build --manifest-path "$SCRIPT_DIR/Cargo.toml"

# Build source-walk (needed for --dev mode)
cargo build --manifest-path "$NGP_DIR/Cargo.toml" \
    -p source-walk --release

# Build the engine
cargo build --manifest-path "$NGP_DIR/Cargo.toml" \
    -p newgameplus --no-default-features --features "$RAFX_FEATURE"

# Run the engine, pointing at extracteroid's target dir for the module dylib
ENGINE="$NGP_DIR/target/debug/newgameplus"
RUST_LOG=info exec "$ENGINE" \
    --module-crate extracteroid \
    --target-dir "$SCRIPT_DIR/target" \
    --module-dir "$SCRIPT_DIR" \
    --dev \
    "$@"
